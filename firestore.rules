rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Trainees ──────────────────────────────────────────────────────
    // Only the coach who created the trainee can read/write.
    match /trainees/{traineeId} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == resource.data.coachId;
      allow create: if request.auth != null
                    && request.resource.data.coachId == request.auth.uid;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.coachId;
    }

    // ── Live Sessions ─────────────────────────────────────────────────
    // • Coach (authenticated): full read/write for their own sessions.
    // • Trainee (via magic link, unauthenticated): can read any session
    //   by ID and update journey fields only — cannot change coachId,
    //   traineeId, or status (those belong to the coach).
    match /live_sessions/{sessionId} {

      // Anyone with the session ID can read (magic-link model).
      allow read: if true;

      // Coach: full write authority.
      allow create: if request.auth != null
                    && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.coachId;

      // Trainee (unauthenticated): may update journey progress fields only.
      // The four protected fields (coachId, traineeId, status, completedAt)
      // must remain unchanged.
      allow update: if request.auth == null
                    && request.resource.data.coachId    == resource.data.coachId
                    && request.resource.data.traineeId  == resource.data.traineeId
                    && (
                         !('status' in request.resource.data)
                         || request.resource.data.status == resource.data.status
                       )
                    && (
                         !('completedAt' in request.resource.data)
                         || request.resource.data.completedAt == resource.data.completedAt
                       );
    }

    // Deny all other collections by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
