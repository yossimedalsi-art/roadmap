rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Trainees ──────────────────────────────────────────────────────
    // Only the coach who created the trainee can read/write.
    match /trainees/{traineeId} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == resource.data.coachId;
      allow create: if request.auth != null
                    && request.resource.data.coachId == request.auth.uid;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.coachId;
    }

    // ── Live Sessions ─────────────────────────────────────────────────
    // • Coach (authenticated): full read/write for their own sessions.
    // • Trainee (via magic link): can read any session by ID and update
    //   journey progress fields. coachId/traineeId are immutable, and
    //   status may only transition to "completed" (natural journey end).
    //   The trainee rule intentionally does NOT require request.auth == null:
    //   a remote device may have any Firebase user signed in (or none),
    //   and the magic-link model treats session-ID knowledge as the grant.
    match /hc_live_sessions/{sessionId} {

      // Anyone with the session ID can read (magic-link model).
      allow read: if true;

      // Coach: full write authority.
      allow create: if request.auth != null
                    && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if request.auth != null
                             && request.auth.uid == resource.data.coachId;

      // Trainee (any auth state): may update journey progress fields.
      // coachId/traineeId must remain unchanged; status may stay the same
      // or move to "completed"; completedAt must remain unchanged.
      allow update: if request.resource.data.coachId    == resource.data.coachId
                    && request.resource.data.traineeId  == resource.data.traineeId
                    && (
                         !('status' in request.resource.data)
                         || request.resource.data.status == resource.data.get('status', null)
                         || request.resource.data.status == "completed"
                       )
                    && (
                         !('completedAt' in request.resource.data)
                         || request.resource.data.completedAt == resource.data.get('completedAt', null)
                       );
    }

    // Deny all other collections by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
